# Stoner-SCF input parameters
# Format: key = value   (lines starting with '#' are ignored)
# Unknown keys are skipped with a warning.

# --- Tight-binding hopping ---
tpi      = 0.3
tdelta   = 0.03
t2xy     = 0.08
t2yzxz   = 0.04
tg       = 0.05

# --- Spin-orbit coupling ---
lam      = 0.3
theta    = 0.0      # polar angle of spin quantization axis (0 = out-of-plane)
phi      = 0.0      # azimuthal angle

# --- Hubbard / Kanamori ---
U        = 4.0      # intraorbital U (also sets KanamoriParams.U unless K_U is given)
J        = 0.8      # Hund's coupling; U_prime = U - 2*J is enforced automatically
# K_U    = 4.0      # override Kanamori U independently of Stoner U
# U_prime = 2.4    # set explicitly to bypass the U - 2*J rule

# --- Interlayer hopping ---
t_perp    = 0.06
t_perp_xy = 0.005

# --- Crystal fields and layer potential ---
delta_cf1 = 0.23    # tetragonal CF layer 1 (positive = xy above yz/xz)
delta_cf2 = -0.16   # tetragonal CF layer 2
delta_V   = 0.0     # staggered layer potential

# --- SCF loop ---
S0       = 0.3      # initial magnetization guess
alpha    = 0.2      # linear mixing parameter
T        = 0.05     # temperature (eV)
N_target = 10.0     # target electron count (5 per layer x 2 layers)
grid     = 50       # k-grid size (grid x grid)
