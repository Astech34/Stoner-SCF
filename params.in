# Stoner-SCF input parameters
# Format: key = value   (lines starting with '#' are ignored)
# Unknown keys are skipped with a warning.

# --- Tight-binding hopping ---
tpi      = 0.3
tdelta   = 0.03
t2xy     = 0.02 # changes xy hump
t2yzxz   = 0.00 # Changes yzxz hump
tg       = 0.05

# --- Spin-orbit coupling ---
lam      = 0.00
theta    = 0     # polar angle of spin quantization axis (0 = out-of-plane)
phi      = 0      # azimuthal angle

# theta    = 1.57079632679     # polar angle of spin quantization axis (0 = out-of-plane)
# phi      = 0.785398163397      # azimuthal angle

# theta = 1.5533 #tilted
# phi = 0.7854

# --- Hubbard / Kanamori ---
U        = 5     # intraorbital U (also sets KanamoriParams.U unless K_U is given)
J        = 1.1      # Hund's coupling; U_prime = U - 2*J is enforced automatically
# K_U    = 4.0      # override Kanamori U independently of Stoner U
# U_prime = 2.4    # set explicitly to bypass the U - 2*J rule

# --- Interlayer hopping ---
t_perp    = 0.01
t_perp_xy = 0.005

#t_perp    = 0.0
#t_perp_xy = 0.0

# --- Crystal fields and layer potential ---
delta_V   = 0.0    # staggered layer potential
delta_cf1 = -0.12    # tetragonal CF layer 1 (positive = xy above yz/xz)
delta_cf2 = -0.12   # tetragonal CF layer 2

# --- SCF loop ---
S0       = 0.3      # initial magnetization guess
alpha    = 0.03      # linear mixing parameter. If zero it uses DIIS
T        = 0.005     # temperature (eV)
N_target = 8.0     # target electron count (5 per layer x 2 layers)
grid     = 50       # k-grid size (grid x grid)

# --- Rho Seed ---
#param_file = /home/cmp/Documents/Github/Stoner-SCF/out/L0010d3_density_matrix.csv
param_file = 
#rho_out_file = /home/cmp/Documents/Github/Stoner-SCF/out/L110_density_matrix.csv
rho_out_file =

# --- Convergance ---
tol = 1e-8

# --- Density-matrix seed (see seeds.h) ---
# seed selects the starting 12x12 density matrix (4 electrons per layer).
#   high_spin : S=1 per layer, t2g degenerate
#   low_spin  : S=0 per layer, t2g degenerate
#   yz/xz/xy  : high spin with minority electron in that orbital (breaks t2g degeneracy)
#   none / empty : disable seeding (fall back to param_file / bootstrap)
# Takes priority over param_file when set.
seed = high_spin
seed_strength = 0.01   # Frobenius norm of random Hermitian perturbation (0 = none)
seed_rng      = 42     # RNG seed for that perturbation